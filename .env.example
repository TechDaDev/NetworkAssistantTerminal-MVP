DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_ENABLED=false
CREDENTIAL_SECRET_KEY=

DATABASE_URL=sqlite:///data/network_assistant.db
PORT_SCAN_TIMEOUT_SECONDS=0.5
DISCOVERY_TIMEOUT_SECONDS=2.0
DOC_FETCH_ENABLED=false
DOC_FETCH_ALLOW_NON_OFFICIAL=false
DOC_FETCH_TIMEOUT_SECONDS=15

RUN_INTEGRATION_TESTS=false
ALLOW_REAL_CONFIG_TESTS=false
ALLOW_REAL_DHCP_TESTS=false

LAB_CISCO_IP=
LAB_CISCO_USERNAME=
LAB_CISCO_PASSWORD=
LAB_CISCO_PLATFORM=cisco_ios
LAB_CISCO_TEST_INTERFACE=
LAB_CISCO_TEST_VLAN=30
LAB_CISCO_TEST_DESCRIPTION=NA-LAB-TEST

LAB_MIKROTIK_IP=
LAB_MIKROTIK_USERNAME=
LAB_MIKROTIK_PASSWORD=
LAB_MIKROTIK_PLATFORM=mikrotik_routeros
LAB_MIKROTIK_TEST_INTERFACE=bridge
LAB_MIKROTIK_TEST_ADDRESS=192.168.50.1/24
LAB_MIKROTIK_DHCP_NAME=na-lab-dhcp
LAB_MIKROTIK_DHCP_POOL_NAME=na-lab-pool
LAB_MIKROTIK_DHCP_NETWORK=192.168.60.0/24
LAB_MIKROTIK_DHCP_GATEWAY=192.168.60.1
LAB_MIKROTIK_DHCP_POOL_RANGE=192.168.60.100-192.168.60.150
LAB_MIKROTIK_DHCP_DNS=8.8.8.8,1.1.1.1
